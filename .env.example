# ── Database ────────────────────────────────────────────────────────────────
# Full asyncpg connection URL.
# For Neon: postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# For local dev (docker-compose.dev.yml): postgresql+asyncpg://dev:dev@localhost:5432/hockey_dev
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Security ────────────────────────────────────────────────────────────────
# Random secret used to sign session tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-at-least-32-random-characters-long

# ── Email (Resend) ──────────────────────────────────────────────────────────
# API key from https://resend.com — used to send magic-link login emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App URL ─────────────────────────────────────────────────────────────────
# Public-facing base URL (no trailing slash).
# Controls: secure cookie flag, CORS origin, TrustedHost middleware.
# Use https:// in production.
BASE_URL=https://yourdomain.com

# ── Session ─────────────────────────────────────────────────────────────────
# How many days a login session stays valid before requiring re-authentication.
SESSION_EXPIRY_DAYS=30

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Token from the Cloudflare Zero Trust dashboard → Networks → Tunnels.
# The tunnel forwards public HTTPS traffic to the app container on port 8000.
# Generate a tunnel at: https://one.dash.cloudflare.com/
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
